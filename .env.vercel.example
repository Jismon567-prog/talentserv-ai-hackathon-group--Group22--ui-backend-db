# Vercel production / preview environment variables
# Copy to .env.vercel.local (gitignored), fill values, then:
#   vercel link
#   ./scripts/sync-vercel-env.sh .env.vercel.local
# Or paste into Vercel → Project → Settings → Environment Variables
# See DEPLOYMENT.md for full setup and Clerk / Supabase configuration.

# --- Clerk (required) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Clerk routing (defaults also in vercel.json) ---
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- LLM (at least one required) ---
OPENAI_API_KEY=
GROQ_API_KEY=

# --- Supabase (optional — generation history) ---
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Optional automation skeleton base URL ---
BASE_URL=https://openmrs-test.example.org
